{
  "mcpServers": {
    "chrome-devtools": {
      "type": "local",
      "command": "npx",
      "tools": [
        "*"
      ],
      "args": [
        "-y",
        "chrome-devtools-mcp@latest",
        "--isolated"
      ]
    },
    "x-ipe-app-and-agent-interaction": {
      "type": "local",
      "command": "uvx",
      "tools": [
        "*"
      ],
      "args": [
        "--from",
        "x-ipe",
        "x-ipe-mcp"
      ]
    }
  }
}